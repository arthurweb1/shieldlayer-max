FROM python:3.11-slim

WORKDIR /app

# Install dashboard requirements + app dependencies needed for config import
COPY requirements.txt requirements-dashboard.txt ./
RUN pip install --no-cache-dir -r requirements.txt -r requirements-dashboard.txt

COPY app/ ./app/
COPY data/ ./data/
COPY dashboard/ ./dashboard/

ENV PYTHONPATH=/app

EXPOSE 8501

CMD ["streamlit", "run", "dashboard/main.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true"]
