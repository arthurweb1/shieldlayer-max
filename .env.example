# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-64-hex-chars-here-00000000000000000000000000000000

# Upstream LLM (drop-in: point your SDK base_url here)
UPSTREAM_OPENAI_BASE=https://api.openai.com/v1
UPSTREAM_ANTHROPIC_BASE=https://api.anthropic.com

# Redis
REDIS_URL=redis://localhost:6379/0
VAULT_TTL=300

# Compliance
GUARDIAN_MAX_REWRITES=3

# Dashboard (CORS allowed origin)
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000
