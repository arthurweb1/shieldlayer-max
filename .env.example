# vLLM backend
VLLM_BASE_URL=http://vllm:8000
VLLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# Use a different model for compliance checking (can be same as VLLM_MODEL)
VLLM_GUARDIAN_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# Path to Hugging Face model cache (default: ~/.cache/huggingface)
HF_HOME=~/.cache/huggingface

# PostgreSQL
# WARNING: Change the password before deploying!
POSTGRES_DSN=postgresql://shieldlayer:CHANGE_ME@postgres:5432/shieldlayer

# Shield settings
SHIELD_SYNONYM_PAIRS_PATH=/app/data/synonym_pairs.json

# Guardian settings
GUARDIAN_MAX_RETRIES=3

# Audit
AUDIT_TOKEN=change-me-to-a-secure-token

# FAISS cache
CACHE_SIMILARITY_THRESHOLD=0.97
