{
  "manifest_version": 3,
  "name": "ShieldLayer Ghost Mode",
  "version": "0.1.0",
  "description": "Routes AI API calls through ShieldLayer gateway for EU AI Act compliance.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "dist/background/service_worker.global.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "dist/content/injector.global.js",
        "dist/content/interceptor.global.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "public/popup.html",
    "default_icon": {
      "16": "public/icon-16.png",
      "48": "public/icon-48.png",
      "128": "public/icon-128.png"
    }
  },
  "icons": {
    "16": "public/icon-16.png",
    "48": "public/icon-48.png",
    "128": "public/icon-128.png"
  }
}
